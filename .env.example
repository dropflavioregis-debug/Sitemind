ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_CONFIDENCE=0.4

# PPE model
ROBOFLOW_PPE_MODEL_ID=ppes-kaxsi/8

# Fashionpedia model (Roboflow Universe, HF dataset equivalent)
ROBOFLOW_FASHIONPEDIA_MODEL_ID=fashionpedia-wnt48/1

# DETR-50 (Hugging Face Inference API)
HF_TOKEN=your_huggingface_token_here
HF_DETR_MODEL_ID=facebook/detr-resnet-50
HF_DETR_CONFIDENCE=0.4

# Optional future HF Gradio fallback (off by default)
# FASHIONPEDIA_PROVIDER=gradio
# HF_FASHIONPEDIA_SPACE_URL=sergiopaniego-detr-object-detection-fashionpedia-fa0081f.hf.space
